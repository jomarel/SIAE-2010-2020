@Article{RodriguezSanchez04,
  Title                    = {{Especialización} y eficiencia en los hospitales españoles. {Un}
 análisis con técnicas de frontera},
  Author                   = {Fernando {Rodríguez López} and {José Ignacio} {Sánchez Macías}},
