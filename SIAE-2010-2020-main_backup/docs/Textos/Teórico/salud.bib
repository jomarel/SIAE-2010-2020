@Book{Robinson99,
  Title                    = {The Corporate Practice of Medicine: Competition and Innovation in
 Health Care},
  Author                   = {Robinson, James C.},
  Publisher                = {University of California Press},
  Year                     = {1999},

  Address                  = {New York: Milbank Memorial Fund},
  Note                     = {888},

  Abstract                 = {Examines the major forms of physician organization that have
 become prominent in the United States in the last years of the
 twentieth century, documenting their strengths and weaknesses in
 order to shed light on the challenges that face corporate forms
 of organization in the health care industry. Explores the
 struggle between regulated and unregulated professionalism in
 health care. Discusses the failure of managed competition and
 describes the system of unmanaged competition. Considers the
 relationship between insurers and providers and discusses the
 virtual integration that has occurred in the health care
 industry. Studies four forms of physician organization:
 multispecialty medical groups, independent practice associations,
 physician practice management firms, and physician-hospital
 organizations. Considers what may happen as the forces of market
 competition and corporate organization are unleashed in the
 health care sector, drawing lessons from the experience of
 utility regulation and deregulation. Robinson is Professor of
 Health Economics at the School of Public Health, University of
 California, Berkeley.}
}

