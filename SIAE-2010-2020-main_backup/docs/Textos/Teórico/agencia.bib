@ARTICLE{ArmstrongVickers00,
  author = {Mark Armstrong and John Vickers},
  year = 2000,
  title = {{Multiproduct} {Price} {Regulation} {Under} {Asymmetric}
          {Information}},
  journal = {Journal of industrial economics},
  volume = {48(2)},
  pages = {137-159},
  note = {pdf},
  abstract = {We discuss the regulation of a multiproduct monopolist when the
             firm has private information about cost or demand conditions. The
             regulator offers the firm a set of prices from which to choose.
             When there is private information only about costs, the firm
             should always have a degree of discretion over its pricing
             policy. When uncertainty concerns demand, whether discretion is
             desirable depends on how demand elasticities vary with the scale
             of demands. If a positive demand shock is associated with a
             reduction in the market elasticity, discretion is good for
             overall welfare; otherwise it is not.}
}
@ARTICLE{ArmstrongRochet99,
  author = {Armstrong,-Mark and Rochet,-Jean-Charles},
  year = 1999,
  title = {{Multi}-Dimensional {Screening}: {A} {User's} {Guide}},
  journal = eer,
  volume = {43(4-6)},
  pages = {959-979},
  note = {pdf},
  abstract = {Multi-dimensional screening models have many potential
             applications but economists have so far been hindered by the
             considerable technical difficulties involved in their resolution.
             This paper studies the simplest formulation of the general
             screening model, and we provide a complete solution to this case.
             We then show how this model can be applied to multi-product
             nonlinear pricing and to multi-product monopoly regulation.
             Finally, we discuss how the model has been applied to other
             economic situations of interest, including auction design and
             optimal taxation.}
}
